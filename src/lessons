      { id: "q13_6", text: "معامل الاحتكاك كمية عددية ليس لها وحدة قياس.", type: "tf", correct: "true", explain: "✅ نعم، لأنه نسبة بين قوتين (قوة الاحتكاك ÷ القوة العمودية)." },
      { id: "q13_7", text: "كلما زادت خشونة السطحين المتلامسين زاد معامل الاحتكاك الفعلي بينهما.", type: "tf", correct: "true", explain: "✅ السطوح الأكثر خشونة تعطي تداخلاً نتوئياً أكبر مما يرفع قيمة معامل الاحتكاك." },
      { id: "q13_8", text: "وجود مواد تزييت وتشحيم على الأسطح يساهم في زيادة قوة الاحتكاك.", type: "tf", correct: "false", explain: "❌ العكس صحيح، فالمزلقات تملأ الفجوات الخشنة وتقلل قوة الاحتكاك لتسهيل الحركة وضمان عدم التأكل." },
      { id: "q13_9", text: "إذا أثرت قوة على جسم وبقي ساكناً، فإن قوة الاحتكاك السكوني تساوي القوة الخارجية تماماً.", type: "tf", correct: "true", explain: "✅ نعم، تتزن القوى ويكون محصلتها صفراً طالما لم يتحرك الجسم بعد." },
      { id: "q13_10", text: "القوة العمودية (ق_ر) تساوي دائماً وزن الجسم (ك × د) تحت شتى الظروف الحركية والمستويات.", type: "tf", correct: "false", explain: "❌ لا تساوي الوزن دائماً، فقد تقل إذا كان المستوى مائلاً (و جتا هـ) أو لو تأثر الجسم بقوة شد مائلة لأعلى." },
      { id: "q13_11", text: "أي العوامل التالية لا يؤثر على قيمة قوة الاحتكاك الحركي؟", type: "mc", options: ["أ) نوع وطبيعة السطحين", "ب) القوة العمودية الضاغطة", "ج) مساحة السطح المتلامس", "د) مستوى خشونة الأسطح"], correct: "ج) مساحة السطح المتلامس", explain: "✅ قوة الاحتكاك مستقلة تماماً عن مساحة الأسطح المتلامسة على عكس الاعتقاد الشائع." },
      { id: "q13_12", text: "إذا أثرت قوة 5 نيوتن على جسم ساكن وزنه 10 نيوتن وبقي ساكناً، فإن لقوة الاحتكاك السكوني قيمة تعادل:", type: "mc", options: ["أ) صفر نيوتن", "ب) 5 نيوتن", "ج) 10 نيوتن", "د) 15 نيوتن"], correct: "ب) 5 نيوتن", explain: "✅ بما أن الجسم بقي ساكناً، فإن الاحتكاك السكوني يتزن مع القوة المطبقة ويعادلها تماماً ومقدارها 5 نيوتن." },
      { id: "q13_13", text: "ما هي وحدة قياس معامل الاحتكاك (م)؟", type: "mc", options: ["أ) النيوتن (N)", "ب) نيوتن . متر (N.m)", "ج) كيلوجرام . م/ث²", "د) ليس له وحدة قياس"], correct: "د) ليس له وحدة قياس", explain: "✅ معامل الاحتكاك هو نسبة بين قوتين (قوة الاحتكاك والقوة الضاغطة) فلذلك تُختصر الوحدات." },
      { id: "q13_14", text: "جسم كتلته 2 كجم على سطح أفقي معامل احتكاكه الحركي 0.3، بافتراض (د = 10 م/ث²)، فما مقدار قوة الاحتكاك الحركي؟", type: "mc", options: ["أ) 2 نيوتن", "ب) 6 نيوتن", "ج) 20 نيوتن", "د) 0.6 نيوتن"], correct: "ب) 6 نيوتن", explain: "✅ القوة العمودية ق_ر = 2 × 10 = 20 نيوتن. الاحتكاك الحركي = μ_ح × ق_ر = 0.3 × 20 = 6 نيوتن." },
      { id: "q13_15", text: "احتكاك إطارات السيارة مع الطريق الإسفلتي الجاف أثناء تدحرجها دون انزلاق هو احتكاك:", type: "mc", options: ["أ) سكوني", "ب) حركي", "ج) مرن", "د) هيدروليكي"], correct: "أ) سكوني", explain: "✅ أثناء التدحرج دون انزلاق، تظل نقاط التماس لحظياً في سكون نسبي مع الطريق، فلذلك هو احتكاك سكوني يحميها من الانزلاق." },
      { id: "q13_16", text: "أي من الإجراءات التالية يساهم بفعالية في تقليص قوة الاحتكاك؟", type: "mc", options: ["أ) زيادة وزن الجسم المنزلق", "ب) زيادة خشونة الأسطح", "ج) التزليق والتزييت للمفاصل", "د) تكبير المساحة السطحية للتلامس"], correct: "ج) التزليق والتزييت للمفاصل", explain: "✅ تعتمد هندسة المزلقات على تكوين طبقة رقيقة تفصل بين النتوءات المجهرية مما يقلص الاحتكاك." },
      { id: "q13_17", text: "أي الخيارات الآتية يعتبر من الأمثلة على الجوانب السلبية والضارة للاحتكاك؟", type: "mc", options: ["أ) تآكل وتلف قطع المحركات الميكانيكية", "ب) المقدرة على المشي والوقوف بثبات", "ج) إمساك القلم والكتابة بوضوح", "د) عمل منظومات المكابح لإيقاف السيارات"], correct: "أ) تآكل وتلف قطع المحركات الميكانيكية", explain: "✅ يتسبب الاحتكاك بالقطع الداخلية للمحركات بالحرارة العالية والتآكل الهيكلي التدريجي." },
      { id: "q13_18", text: "عند مضاعفة القوة العمودية التي تضغط بها الأجسام على المستويات، فإن قوة الاحتكاك الحركي:", type: "mc", options: ["أ) تقل للنصف", "ب) تزداد للضعف", "ج) تظل ثابتة دون تأثر", "د) تقل للربع"], correct: "ب) تزداد للضعف", explain: "✅ العلاقة طردية خطية مباشرة بين الاحتكاك الحركي والقوة العمودية (ق_ح = μ_ح × ق_ر)." },
